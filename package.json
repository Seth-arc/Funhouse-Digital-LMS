{
  "name": "funhouse-lms",
  "version": "1.0.0",
  "description": "Funhouse LMS — digital literacy platform for grades 4–9",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "npm --prefix server run start",
    "railway:build": "npm --prefix server ci --include=dev && npm --prefix server run build",
    "railway:start": "npm run start",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "audit:deploy:supabase": "node scripts/supabase-predeploy-audit.cjs",
    "audit:deploy:supabase:strict": "node scripts/supabase-predeploy-audit.cjs --strict"
  },
  "keywords": ["lms", "education", "game-based-learning"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
